# Server Configuration
PORT=3001
NODE_ENV=development

# Comma-separated origins (tanpa spasi) untuk CORS, contoh:
# CORS_ORIGINS=https://safezone-campus.vercel.app,https://www.domainmu.com
CORS_ORIGINS=http://localhost:5173

# MySQL Configuration
# Pilih salah satu:
# 1) DATABASE_URL (umumnya hosting seperti Railway)
# Paste DATABASE_URL dari provider DB kamu (Recommended):
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DB_NAME
#
# 2) Konfigurasi terpisah (lokal)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=safezone_campus

JWT_SECRET=change_me_to_strong_secret
JWT_EXPIRES_IN=24h

# Token untuk mengaktifkan endpoint /api/auth/seed dan /api/auth/reset-admin di production
# Kirim via header: X-Bootstrap-Token: <token>
BOOTSTRAP_TOKEN=change_me

# Optional: seed admin default saat boot
DEFAULT_ADMIN_NIM=admin001
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Admin SafeZone
DEFAULT_ADMIN_FACULTY=fit
